<template>
  <section class="recent-practice" v-if="items.length > 0">
    <div class="section-header">
      <h2 class="section-title">🕐 最近练习</h2>
      <span class="section-hint" v-if="items.length > 1">继续上次的进度</span>
    </div>
    <div class="recent-list">
      <div
        v-for="item in items"
        :key="item.id"
        class="recent-item"
        @click="$emit('resume', item)"
      >
        <div class="ri-progress">
          <svg class="ri-ring" viewBox="0 0 36 36">
            <circle class="ri-ring-bg" cx="18" cy="18" r="15.5" />
            <circle
              class="ri-ring-fill"
              cx="18" cy="18" r="15.5"
              :style="{ strokeDasharray: progressDash(item.progress), strokeDashoffset: 0 }"
            />
          </svg>
          <span class="ri-pct">{{ Math.round((item.progress || 0) * 100) }}%</span>
        </div>
        <div class="ri-info">
          <span class="ri-node">{{ item.nodeName }}</span>
          <span class="ri-meta">
            {{ formatDate(item.time) }}
            <template v-if="item.correctRate !== undefined">
              · 正确率 {{ Math.round(item.correctRate * 100) }}%
            </template>
          </span>
        </div>
        <span class="ri-cta">继续</span>
      </div>
    </div>
  </section>
</template>

<script setup>
defineProps({
  items: { type: Array, default: () => [] },
})
defineEmits(['resume'])

const CIRCUMFERENCE = 2 * Math.PI * 15.5

function progressDash(progress) {
  const p = Math.min(Math.max(progress || 0, 0), 1)
  return `${CIRCUMFERENCE * p} ${CIRCUMFERENCE}`
}

function formatDate(iso) {
  if (!iso) return ''
  try {
    const d = new Date(iso)
    const now = new Date()
    const diff = now - d
    if (diff < 3600000) return `${Math.floor(diff / 60000)} 分钟前`
    if (diff < 86400000) return `${Math.floor(diff / 3600000)} 小时前`
    if (diff < 604800000) return `${Math.floor(diff / 86400000)} 天前`
    return d.toLocaleDateString('zh-CN', { month: 'short', day: 'numeric' })
  } catch { return '' }
}
</script>

<style scoped>
.recent-practice {
  margin-bottom: var(--space-8);
}

.section-header {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: var(--space-4);
}

.section-title {
  font-size: var(--text-lg);
  font-weight: var(--font-bold);
  color: var(--text-main);
  margin: 0;
  letter-spacing: -0.2px;
}

.section-hint {
  font-size: var(--text-xs);
  color: var(--text-tertiary);
}

.recent-list {
  display: flex;
  flex-direction: column;
  gap: var(--space-3);
}

.recent-item {
  display: flex;
  align-items: center;
  gap: var(--space-4);
  padding: var(--space-3) var(--space-5);
  background: var(--bg-elevated);
  border: 1px solid var(--border-light);
  border-radius: var(--radius-md);
  cursor: pointer;
  transition: all var(--transition-fast);
}

.recent-item:hover {
  border-color: rgba(200,76,90, 0.15);
  background: rgba(200,76,90, 0.02);
}

.recent-item:hover .ri-cta {
  background: var(--color-primary);
  color: #fff;
}

.ri-progress {
  position: relative;
  width: 40px;
  height: 40px;
  flex-shrink: 0;
}

.ri-ring {
  width: 40px;
  height: 40px;
  transform: rotate(-90deg);
}

.ri-ring-bg {
  fill: none;
  stroke: var(--bg-tertiary);
  stroke-width: 2.5;
}

.ri-ring-fill {
  fill: none;
  stroke: var(--color-primary);
  stroke-width: 2.5;
  stroke-linecap: round;
  transition: stroke-dasharray 0.6s ease;
}

.ri-pct {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 10px;
  font-weight: var(--font-bold);
  color: var(--color-primary);
}

.ri-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.ri-node {
  font-size: var(--text-sm);
  font-weight: var(--font-semibold);
  color: var(--text-main);
}

.ri-meta {
  font-size: 11px;
  color: var(--text-tertiary);
}

.ri-cta {
  padding: 6px 18px;
  border-radius: var(--radius-sm);
  background: rgba(200,76,90, 0.08);
  color: var(--color-primary);
  font-size: var(--text-xs);
  font-weight: var(--font-bold);
  transition: all var(--transition-fast);
  white-space: nowrap;
}

@media (max-width: 600px) {
  .recent-item { padding: var(--space-3) var(--space-4); }
}
</style>

